/* {{name}} — 基础样式 */
@import url('https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.css');

* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #faf7f2;
  --card: #fffdf8;
  --text: #2c3e3a;
  --muted: #9c8b78;
  --accent: {{color}};
  --border: rgba(139, 90, 43, 0.12);
  --radius: 8px;
}

body {
  font-family: "LXGW WenKai", sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  padding: 24px;
}

.header {
  margin-bottom: 24px;
}

.header h1 {
  font-size: 1.5rem;
  font-weight: 600;
}

.form {
  display: flex;
  gap: 8px;
  margin-bottom: 20px;
}

.form input {
  flex: 1;
  padding: 10px 14px;
  border: 1.5px dashed var(--border);
  border-radius: var(--radius);
  font: inherit;
  background: var(--card);
}

.form input:focus {
  outline: none;
  border-color: var(--accent);
  border-style: solid;
}

.form button {
  padding: 10px 18px;
  background: var(--accent);
  color: #fff;
  border: none;
  border-radius: var(--radius);
  font: inherit;
  cursor: pointer;
}

.list { display: flex; flex-direction: column; gap: 6px; }

.item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
}

.item__title { flex: 1; font-size: 0.9rem; }
.item__delete {
  color: var(--muted);
  cursor: pointer;
  border: none;
  background: none;
  font-size: 1.1rem;
}
.item__delete:hover { color: #c75450; }
